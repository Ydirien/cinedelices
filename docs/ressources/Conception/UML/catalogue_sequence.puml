@startuml

title Recherche et filtrage du catalogue — Ciné Délices

actor Utilisateur as U
participant Frontend as F #B8B0F0
participant Backend as B #9FE1CB
participant Middleware as M #FAC775
database "Base de données" as DB #F5C4B3

== Chargement initial du catalogue ==

U -> F : Accède à la page catalogue
F -> B : GET /recipes
B -> DB : SELECT toutes les recettes\n(titre, catégorie, film/série, image)
DB --> B : Liste des recettes
B --> F : 200 OK + recettes
F --> U : Affiche le catalogue complet

== Recherche par mot-clé ==

U -> F : Saisit un mot-clé\n(titre de recette ou film/série)
F -> M : Debounce la saisie (300ms)
M --> F : Requête prête à envoyer
F -> B : GET /recipes?search=\{mot-clé\}
B -> DB : SELECT recettes WHERE titre\nOU film/série LIKE \{mot-clé\}
DB --> B : Recettes correspondantes

alt Aucun résultat
    B --> F : 200 OK + tableau vide
    F --> U : Affiche "Aucune recette trouvée"
else Résultats trouvés
    B --> F : 200 OK + recettes filtrées
    F --> U : Met à jour l'affichage
end

== Filtrage par catégorie ==

U -> F : Sélectionne une catégorie\n(entrée, plat, dessert)
F -> B : GET /recipes?category=\{catégorie\}
B -> M : Valide le paramètre catégorie
M --> B : Paramètre valide
B -> DB : SELECT recettes WHERE catégorie = \{catégorie\}
DB --> B : Recettes de la catégorie
B --> F : 200 OK + recettes filtrées
F --> U : Met à jour l'affichage

== Combinaison recherche + filtre ==

U -> F : Saisit un mot-clé ET\nsélectionne une catégorie
F -> B : GET /recipes?search=\{mot-clé\}&category=\{catégorie\}
B -> M : Valide les paramètres
M --> B : Paramètres valides
B -> DB : SELECT recettes WHERE\n(titre OU film/série LIKE \{mot-clé\})\nAND catégorie = \{catégorie\}
DB --> B : Recettes correspondantes

alt Aucun résultat
    B --> F : 200 OK + tableau vide
    F --> U : Affiche "Aucune recette trouvée"
else Résultats trouvés
    B --> F : 200 OK + recettes filtrées
    F --> U : Met à jour l'affichage
end

@enduml
