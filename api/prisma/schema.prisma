
generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               Int       @id @default(autoincrement())
  username         String    @unique
  email            String    @unique
  password         String
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  recipes          Recipe[]
  refreshTokens    RefreshToken[]
  likes            Like[]
  comments         Comment[]
  role             Role      @default(USER)
  resetToken       String?   @unique @map("reset_token")
  resetTokenExpiry DateTime? @map("reset_token_expiry") @db.Timestamptz

  @@map("user")
}

model Ingredient {
  id                Int                @id @default(autoincrement())
  name              String             @unique
  image             String
  recipeIngredients RecipeIngredient[]

  @@map("ingredient")
}

model Recipe {
  id                Int                @id @default(autoincrement())
  title             String
  description       String
  steps             Step[]
  image             String
  prepTime          Int                @map("prep_time")
  cookTime          Int                @map("cook_time")
  servings          Int
  difficulty        Difficulty
  state             State              @default(PENDING)
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz
  userId            Int                @map("user_id")
  user              User               @relation(fields: [userId], references: [id])
  workId            Int                @unique @map("work_id")
  work              Work               @relation(fields: [workId], references: [id])
  recipeIngredients RecipeIngredient[]
  thematics         RecipeThematic[]
  likes             Like[]
  comments          Comment[]

  @@map("recipe")
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  score     Int
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  userId    Int      @map("user_id")
  recipeId  Int      @map("recipe_id")
  user      User     @relation(fields: [userId], references: [id])
  recipe    Recipe   @relation(fields: [recipeId], references: [id])

  @@unique([userId, recipeId])
  @@map("comment")
}

model Like {
  userId    Int      @map("user_id")
  recipeId  Int      @map("recipe_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  user      User     @relation(fields: [userId], references: [id])
  recipe    Recipe   @relation(fields: [recipeId], references: [id])

  @@id([userId, recipeId])
  @@map("like")
}

model Step {
  id       Int    @id @default(autoincrement())
  order    Int
  content  String
  recipeId Int    @map("recipe_id")
  recipe   Recipe @relation(fields: [recipeId], references: [id])

  @@map("step")
}

model RecipeIngredient {
  id           Int        @id @default(autoincrement())
  recipeId     Int        @map("recipe_id")
  ingredientId Int        @map("ingredient_id")
  quantity     Float
  unit         String
  recipe       Recipe     @relation(fields: [recipeId], references: [id])
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])

  @@map("recipe_ingredient")
}

model Thematic {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String
  recipes     RecipeThematic[]

  @@map("thematic")
}

model RecipeThematic {
  recipeId    Int      @map("recipe_id")
  thematicId  Int      @map("thematic_id")
  recipe      Recipe   @relation(fields: [recipeId], references: [id])
  thematic    Thematic @relation(fields: [thematicId], references: [id])

  @@id([recipeId, thematicId])
  @@map("recipe_thematic")
}

model Work {
  id          Int      @id @default(autoincrement())
  title       String
  releaseYear Int      @map("release_year")
  synopsis    String
  image       String
  categoryId  Int      @map("category_id")
  category    Category @relation(fields: [categoryId], references: [id])
  recipe      Recipe?

  @@map("work")
}

model Category {
  id          Int    @id @default(autoincrement())
  name        String @unique
  description String
  image       String
  works       Work[]

  @@map("category")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String
  userId            Int                @map("user_id")
  user              User               @relation(fields: [userId], references: [id])
  issuedAt  DateTime @default(now()) @map("issued_at") @db.Timestamptz
  expiresAt DateTime @map("expires_at") @db.Timestamptz

  @@map("refresh_token")
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum State {
  PENDING
  APPROVED
  REJECTED
}

enum Role {
  USER
  ADMIN
}